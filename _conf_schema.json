{
    "maibot_ws_url": {
        "type": "string",
        "description": "MaiBot WebSocket 地址",
        "default": "ws://127.0.0.1:18040/ws"
    },
    "maibot_api_key": {
        "type": "string",
        "description": "MaiBot API Key",
        "default": ""
    },
    "maibot_platform": {
        "type": "string",
        "description": "MaiBot 平台标识",
        "default": "astrbot"
    },
    "maibot_timeout": {
        "type": "int",
        "description": "WebSocket 请求超时时间（秒）",
        "default": 120
    },
    "maibot_bot_qq": {
        "type": "string",
        "description": "Bot QQ 号",
        "default": ""
    },
    "maibot_bot_nickname": {
        "type": "string",
        "description": "Bot 昵称",
        "default": ""
    }
}
